+#ifdef GUANACO_ENABLED
+void llama_model_base::load_expert_tensors(llama_model_loader & ml) {
+    // Register expert tensors with Guanaco for streaming
+    for (int il = 0; il < (int)layers.size(); ++il) {
+        auto & layer = layers[il];
+        const auto tn = LLM_TN(arch);
+        
+        // Register expert tensors that will be streamed
+        if (layer.ffn_gate_exps) {
+            guanaco_expert_hook_instance->register_tensor(tn(LLM_TENSOR_FFN_GATE_EXPS, "weight", il).c_str(), il, -1);
+        }
+        if (layer.ffn_up_exps) {
+            guanaco_expert_hook_instance->register_tensor(tn(LLM_TENSOR_FFN_UP_EXPS, "weight", il).c_str(), il, -1);
+        }
+        if (layer.ffn_down_exps) {
+            guanaco_expert_hook_instance->register_tensor(tn(LLM_TENSOR_FFN_DOWN_EXPS, "weight", il).c_str(), il, -1);
+        }
+    }
+}
+#endif
