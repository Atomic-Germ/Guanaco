+#ifdef GUANACO_ENABLED
+// Guanaco integration: check if tensor is an expert tensor
+bool is_expert_tensor_name(const std::string& name) {
+    return name.find("ffn_up_exps") != std::string::npos ||
+           name.find("ffn_down_exps") != std::string::npos ||
+           name.find("ffn_gate_exps") != std::string::npos ||
+           name.find(".experts.") != std::string::npos;
+}
+
+// Guanaco integration: extract layer and expert index from tensor name
+bool parse_expert_tensor_info(const std::string& name, int& layer_idx, int& expert_idx) {
+    layer_idx = -1; expert_idx = -1;
+    const char* layer_marker = strstr(name.c_str(), "blk.");
+    if (!layer_marker) layer_marker = strstr(name.c_str(), "layers.");
+    if (layer_marker) {
+        layer_idx = strtol(layer_marker + 4, nullptr, 10);
+    }
+    const char* expert_marker = strstr(name.c_str(), ".experts.");
+    if (!expert_marker) expert_marker = strstr(name.c_str(), "exps.");
+    if (expert_marker) {
+        expert_idx = strtol(expert_marker + (strstr(expert_marker, ".experts.") ? 9 : 5), nullptr, 10);
+    }
+    return layer_idx >= 0 || expert_idx >= 0;
+}
+#endif
