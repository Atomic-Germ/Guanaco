+#ifdef GUANACO_ENABLED
+// Guanaco integration: helper to extract top-k indices from selected_experts tensor
+static std::vector<int> extract_topk_indices(ggml_tensor* selected_experts, int n_expert_used) {
+    std::vector<int> result;
+    if (!selected_experts) return result;
+    const int32_t* data = static_cast<const int32_t*>(selected_experts->data);
+    if (!data) return result;
+    int64_t n_tokens = selected_experts->ne[1];
+    int64_t n_experts = selected_experts->ne[0];
+    for (int64_t t = 0; t < n_tokens; ++t) {
+        for (int64_t k = 0; k < n_expert_used && k < n_experts; ++k) {
+            result.push_back(data[k * n_tokens + t]);
+        }
+    }
+    std::sort(result.begin(), result.end());
+    result.erase(std::unique(result.begin(), result.end()), result.end());
+    return result;
+}
+#endif
