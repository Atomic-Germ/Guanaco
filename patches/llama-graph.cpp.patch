+// Guanaco integration: redirect expert tensor data to streaming buffers
+static void guanaco_redirect_expert_tensors(int layer_idx, const std::vector<int>& expert_ids,
+                                            ggml_tensor* up_exps, ggml_tensor* gate_exps, ggml_tensor* down_exps,
+                                            const llm_graph_context* ctx) {
+    if (!ctx->model->use_guanaco_streaming()) return;
+    auto hook = ctx->model->get_guanaco_hook();
+    for (int expert_id : expert_ids) {
+        if (up_exps)   hook->redirect_tensor_data(up_exps,   layer_idx, expert_id, 0);
